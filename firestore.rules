rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // كل حد يقدر يقرأ ويكتب في مستندات دكاكين (products, users)
    // ده مناسب للتجربة بس؛ لو الموقع هيشتغل فعلي، لازم تضيّق الصلاحيات دي
    // (مثلاً تسمح بالكتابة بس لمستخدمين مسجلين عن طريق Firebase Auth).
    match /dakakeen/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
